{
	"name": "movies",
	"private": true,
	"homepage": "https://sdlmdev.github.io/Movies/",
	"type": "module",
	"engines": {
		"node": ">=22.11.0",
		"npm": ">=10.9.0"
	},
	"scripts": {
		"start": "npm run build && npm run preview -- --open",
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "eslint . --max-warnings 0",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"stylelint": "stylelint \"src/**/*.{scss,css}\"",
		"stylelint:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:visual": "playwright test",
		"test:visual:ui": "playwright test --ui",
		"test:all": "npm run test && npm run build && npm run test:visual",
		"prepare": "husky",
		"predeploy": "tsc -b && npx cross-env VITE_APP_GH_PAGES=true vite build",
		"deploy": "gh-pages -d dist"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.69.0",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@vkontakte/vkui": "^7.11.6",
		"axios": "^1.8.4",
		"classnames": "^2.5.1",
		"i18next": "^24.2.3",
		"i18next-browser-languagedetector": "^8.0.4",
		"i18next-resources-to-backend": "^1.2.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-i18next": "^15.4.1",
		"react-router": "^7.4.0",
		"react-virtuoso": "^4.18.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.0",
		"@commitlint/config-conventional": "^19.8.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.23.0",
		"@playwright/test": "^1.51.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.5.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/react": "^19.0.10",
		"@types/react-dom": "^19.0.4",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^3.0.9",
		"babel-plugin-react-compiler": "^1.0.0",
		"commitlint": "^19.8.0",
		"eslint": "^9.23.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-i18next": "^6.1.3",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.4",
		"eslint-plugin-react-compiler": "^19.1.0-rc.2",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"eslint-plugin-unused-imports": "^4.4.1",
		"gh-pages": "^6.3.0",
		"globals": "^16.0.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^15.5.0",
		"prettier": "^3.5.3",
		"sass": "^1.86.0",
		"stylelint": "^16.17.0",
		"stylelint-config-clean-order": "^8.0.1",
		"stylelint-config-standard-scss": "^14.0.0",
		"stylelint-no-unsupported-browser-features": "^8.1.1",
		"stylelint-order": "^8.1.1",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.28.0",
		"vite": "^6.2.3",
		"vite-plugin-pwa": "^0.21.1",
		"vitest": "^3.0.9"
	}
}
